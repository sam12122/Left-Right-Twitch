{
  "manifest_version": 3,
  "name": "Left-Right Twitch",
  "version": "1.0.0",
  "description": "讓 Twitch 聊天室可以在左側或右側顯示",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "切換聊天室位置"
  },
   "icons": {
   "16": "icon/extension_icon16.png",
   "32": "icon/extension_icon32.png",
   "48": "icon/extension_icon48.png",
   "128": "icon/extension_icon128.png"
 }
}