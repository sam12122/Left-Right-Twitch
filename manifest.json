{
  "manifest_version": 3,
  "name": "Twitch Chat Switcher",
  "version": "1.0.0",
  "description": "讓 Twitch 聊天室可以在左側或右側顯示",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "切換聊天室位置"
  }
}